{
  "expo": {
    "name": "Swolemates",
    "slug": "Swolemates",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swolemates",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abefqy.Swolemates",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app requires access to your location to find nearby gyms and workout partners.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app requires access to your location to find nearby gyms and workout partners.",
        "NSLocationAlwaysUsageDescription": "This app requires access to your location to find nearby gyms and workout partners."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBT6rcaMi9yQx43atgaVxptmvJAfMm4CHk"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/swolematesSplash.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.abefqy.Swolemates",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-location",
      [
        "expo-image-picker",
        {
          "photoPermission" : "The app accesses your photos to let you share them with your friends"
        }
      ],
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/swolematesSplash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "958b7a48-6689-468f-89b2-da2e40212483"
      }
    }
  }
}